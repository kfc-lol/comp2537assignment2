<%- include('templates/header') %>
  <h2>Log In</h2>

  <% if (error) { %>
    <div class="alert alert-danger mt-3"><%= error %></div>
  <% } %>

  <form action="/loginSubmit" method="POST" class="mt-3">
    <div class="mb-2">
      <label class="form-label">Email</label>
      <input name="email" type="email" class="form-control" placeholder="you@example.com" required />
    </div>
    <div class="mb-2">
      <label class="form-label">Password</label>
      <input name="password" type="password" class="form-control" placeholder="Password" required />
    </div>
    <button type="submit" class="btn btn-primary w-100">Log In</button>
  </form>

  <p class="mt-1 text-center">Don't have an account? <a href="/signup">Sign Up</a></p>
<%- include('templates/footer') %>